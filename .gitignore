# ──────────────────────────────────────────────
# Beacon — root .gitignore
# ──────────────────────────────────────────────

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST
.venv/
venv/
ENV/
env/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.turbo/

# Testing
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# Docker
*.env.docker

# Misc
*.pem
*.key
*.cert