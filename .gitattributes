# ──────────────────────────────────────────────
# Beacon — .gitattributes
# Normalizes line endings across all platforms.
# Prevents Windows CRLF from corrupting files.
# ──────────────────────────────────────────────

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly declare text files
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.html      text eol=lf
*.py        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.env*      text eol=lf
*.gitignore text eol=lf

# Binary files — do not modify line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary